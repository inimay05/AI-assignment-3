import random

def dynamic_navigation(grid, start, goal, steps=50):
    from copy import deepcopy
    import heapq

    def heuristic(a, b):
        return abs(a[0] - b[0]) + abs(a[1] - b[1])

    def astar(grid, start, goal):
        open_set = [(0, start)]
        came_from = {}
        g_score = {start: 0}

        while open_set:
            _, current = heapq.heappop(open_set)

            if current == goal:
                path = []
                while current in came_from:
                    path.append(current)
                    current = came_from[current]
                path.append(start)
                return path[::-1]

            x, y = current
            for dx, dy in [(1,0), (-1,0), (0,1), (0,-1)]:
                nx, ny = x + dx, y + dy

                if 0 <= nx < 20 and 0 <= ny < 20 and grid[nx][ny] == 0:
                    neighbor = (nx, ny)
                    tentative_g = g_score[current] + 1

                    if neighbor not in g_score or tentative_g < g_score[neighbor]:
                        came_from[neighbor] = current
                        g_score[neighbor] = tentative_g
                        f = tentative_g + heuristic(neighbor, goal)
                        heapq.heappush(open_set, (f, neighbor))

        return None

    current = start
    path = astar(grid, start, goal)

    for step in range(steps):
        if not path:
            print("No path available")
            return

        current = path.pop(0)

        # introduce random obstacle
        ox, oy = random.randint(0, 19), random.randint(0, 19)
        grid[ox][oy] = 1

        # replan if needed
        if current not in path:
            path = astar(grid, current, goal)

        if current == goal:
            print("Reached Goal!")
            return

    print("Stopped after steps")


# Run
grid = [[0]*20 for _ in range(20)]
dynamic_navigation(grid, (0, 0), (19, 19))
