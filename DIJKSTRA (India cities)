import heapq

class Graph:
    def __init__(self):
        self.edges = {}

    def add_edge(self, u, v, w):
        self.edges.setdefault(u, []).append((v, w))
        self.edges.setdefault(v, []).append((u, w))  # undirected

    def dijkstra(self, start):
        pq = [(0, start)]
        dist = {start: 0}
        parent = {start: None}

        while pq:
            curr_dist, node = heapq.heappop(pq)

            for neighbor, weight in self.edges.get(node, []):
                new_dist = curr_dist + weight
                if neighbor not in dist or new_dist < dist[neighbor]:
                    dist[neighbor] = new_dist
                    parent[neighbor] = node
                    heapq.heappush(pq, (new_dist, neighbor))

        return dist, parent

    def get_path(self, parent, goal):
        path = []
        while goal:
            path.append(goal)
            goal = parent.get(goal)
        return path[::-1]


# Sample Indian cities graph
g = Graph()
g.add_edge("Hyderabad", "Bangalore", 570)
g.add_edge("Hyderabad", "Chennai", 630)
g.add_edge("Bangalore", "Chennai", 350)
g.add_edge("Bangalore", "Mumbai", 980)
g.add_edge("Mumbai", "Delhi", 1400)
g.add_edge("Chennai", "Kolkata", 1650)
g.add_edge("Delhi", "Kolkata", 1500)

start = "Hyderabad"

distances, parents = g.dijkstra(start)

print("Shortest distances from", start)
for city in distances:
    print(city, ":", distances[city])

print("Path to Delhi:", g.get_path(parents, "Delhi"))
